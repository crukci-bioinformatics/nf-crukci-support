// Example Nextflow configuration for nf-crukci-logscan plugin

plugins {
    id 'nf-crukci-logscan@1.0.0-SNAPSHOT'
}

// Log scan configuration
logScan {
    // Enable/disable the plugin
    enabled = true

    // Scan logs of successful tasks
    scanOnSuccess = false

    // Scan logs of failed tasks
    scanOnFailure = true

    // Maximum number of lines to scan per log file (0 = unlimited)
    maxLinesToScan = 10000

    // Enable verbose debug logging
    verbose = true

    // Patterns to search for in log files
    patterns = [
        // Simple string pattern - auto-detects memory limit patterns
        // Any pattern containing "memory limit" automatically gets exit code 137
        'Exceeded job memory limit',

        // Additional patterns with detailed configuration
        [
            pattern: 'ERROR',
            name: 'Generic Error',
            caseSensitive: true,
            exitCode: null  // No exit code override - uses actual task exit code
        ],
        [
            pattern: 'out of memory',
            name: 'OOM Pattern',
            caseSensitive: false,
            exitCode: 137  // Override exit code to 137 to trigger memory-based retry
        ],
        [
            pattern: 'CUDA out of memory',
            name: 'GPU Memory Error',
            caseSensitive: true,
            exitCode: 140  // Custom exit code for GPU memory issues
        ]
    ]
}

// Process configuration to enable retries based on exit codes
process {
    // Use a closure to determine error strategy based on exit code
    errorStrategy = { task.exitStatus == 137 ? 'retry' : task.exitStatus == 140 ? 'retry' : 'terminate' }
    maxRetries = 3

    // Dynamic memory allocation based on retry attempt
    // Increase memory on retries triggered by exit code 137
    memory = { task.exitStatus == 137 ? 4.GB * task.attempt : 4.GB }
}

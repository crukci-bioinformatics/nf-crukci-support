// Example Nextflow configuration for nf-crukci-logscan plugin

plugins {
    id 'nf-crukci-logscan@1.0.0-SNAPSHOT'
}

// Log scan configuration
logScan {
    // Enable/disable the plugin
    enabled = true
    
    // Scan logs of successful tasks
    scanOnSuccess = false
    
    // Scan logs of failed tasks
    scanOnFailure = true
    
    // Maximum number of lines to scan per log file (0 = unlimited)
    maxLinesToScan = 10000
    
    // Enable verbose debug logging
    verbose = false
    
    // Patterns to search for in log files
    patterns = [
        // Simple string pattern - auto-detects memory limit for retry
        // Memory patterns automatically get exit code 137
        'Exceeded job memory limit',
        
        // Additional patterns with detailed configuration
        [
            pattern: 'ERROR',
            name: 'Error Pattern',
            caseSensitive: true,
            triggerRetry: false,
            exitCode: null  // No exit code override
        ],
        [
            pattern: 'out of memory',
            name: 'OOM Pattern',
            caseSensitive: false,
            triggerRetry: true,
            exitCode: 137  // Exit code 137 to trigger memory-based retry
        ],
        [
            pattern: 'CUDA out of memory',
            name: 'GPU Memory Error',
            caseSensitive: true,
            triggerRetry: true,
            exitCode: 140  // Custom exit code for GPU memory issues
        ]
    ]
}

// Process configuration to enable retries
process {
    // Default error strategy for all processes
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Dynamic memory allocation based on retry attempt
    memory = { 4.GB * task.attempt }
}

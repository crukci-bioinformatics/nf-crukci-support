/*
 * Example configuration for testing extension functions
 */

plugins {
    id 'nf-crukci-support@1.0.0'
}

// Optional: Configure Java memory parameters
params {
    java_metaspace_size = 128
    java_overhead_size = 64
}

// LogScan configuration is not needed for extension functions
// but the plugin must be loaded via the plugins block above
